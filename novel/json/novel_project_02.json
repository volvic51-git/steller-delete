    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "助けてくれてありがとう。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "どういたしまして。"
    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "お礼に骨を一本どうぞ。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "いらないわ。"
    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "遠慮しなくていいのに。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "本当にいらない。"
    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "じゃあ口紅にしておく？"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "選択肢がおかしくない？"
    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "骨味の口紅なんだけど。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "余計にいらないわ。"
    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "人気あるのに？"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "誰に？"
    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "骨に。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "骨が口紅をするの？"
    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "むしろ骨以外はあまり使わないね。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal2",
      "text": "初耳だよ。"
    },
    {
      "type": "dialog",
      "speaker": "ルージュ",
      "portrait": "normal1",
      "text": "耳があるうちにね。"
    },
