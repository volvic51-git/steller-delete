    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "海って不思議ね。"
    },
    {
      "type": "show",
      "character": "abis",
      "portrait": "normal1"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "ヒトデも不思議よ。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "どっちの話をしているの？"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "海のほう。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "ヒトデじゃなかったの？"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "ヒトデは海の考えごとみたいなものだから。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "考えごとには見えないわ。"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "見えたら考えごとじゃないもの。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "それもそうかしら。"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "ヒトデは目があるけれど、腕の先にあるの。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal2",
      "text": "本当に？"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "ええ。だから海の隅々まで見ようとして広がったのよ。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "努力家さんね。"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "でも海は丸いでしょう。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "多分ね。"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "だから全部は見えないの。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "努力が報われていないわ。"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "でもヒトデは怒らない。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "賢いのね。"
    },
    {
      "type": "dialog",
      "speaker": "アビス",
      "portrait": "normal1",
      "text": "忘れただけよ。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal2",
      "text": "それなら私にもできそうだわ。"
    },
