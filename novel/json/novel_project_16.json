      "text": "ポポポ"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal3",
      "text": "インストール完了"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "あと何個？"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "あと３個"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "次は何の話？"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "次は運命の話を聞きたい"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "運命か・・・"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "最初から決まっていた出会いとか"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "運命って、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "冷たいものだと思ってた"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "信じてなかった？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "信じるとかじゃなくて、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "本当に運命だったかなんて、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "誰にも証明できないでしょ？"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "できない証明はないよ"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "そうなの？"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "５６億光年たっても、わからない証明もあるけど"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "できてないじゃん"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "・・・"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "あの日、エリカに出会えたことが運命なら"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "その出会いが、運命になったんじゃないかな"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "難解　難解"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "私にもわかんないよ"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "でもね、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "最初から答えが決まっているとか、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "そんなんじゃなくて、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "出会いを、大切な意味に変えられるかどうか、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "良い運命にできたかどうか、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "そのくらいのものだと思う"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "そんな気がしたから"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "僕と出会ったことも？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal3",
      "text": "かもね"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "来た！"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "来た来た来た来た来たー！"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal3",
      "text": "運命が来たーーー！"
    },
