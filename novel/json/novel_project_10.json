    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "「やぁ」じゃないわよ。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "パーティーは終わっちゃったわよ。"
    },
    {
      "type": "dialog",
      "speaker": "フラット",
      "portrait": "normal1",
      "text": "あれ、アリスだ。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "「アリスだ。」じゃないわよ。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal2",
      "text": "消滅したかと思ったわ。"
    },
    {
      "type": "dialog",
      "speaker": "フラット",
      "portrait": "normal1",
      "text": "消滅はしたよ。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "・・・。"
    },
    {
      "type": "dialog",
      "speaker": "フラット",
