      "text": "・・・。"
    },
    {
      "type": "dialog",
      "speaker": "アリス",
      "portrait": "normal1",
      "text": "じゃあ、なんでいるのよ。"
    },
    {
      "type": "dialog",
      "speaker": "フラット",
      "portrait": "normal3",
      "text": "・・・"
    },
    {
      "type": "dialog",
      "speaker": "フラット",
      "portrait": "normal1",
      "text": "道に迷ったからかな？"
