      "text": "ポポポ"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal3",
      "text": "インストール完了"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "いよいよ、だね。"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "あと１個"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "なんだか寂しいわね"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "まだ家に帰りたい？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "帰りたい"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "帰れるかな"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "帰れるよ"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "ありがと"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "有栖は強いよね"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "今までの話を聞いていると、"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "弱そうなのに"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "時間がなかったの"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "５６億年もあったのに？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "なにそれ\nそっか"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "人間は１００年くらいしか生きられないんだ"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "個としてはそうだね"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "どういうこと？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "ま、いっか"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "エリカ、病気だったんだ"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "もう手遅れだった"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "死んだ？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "・・・・・。"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "エリカが生きている間に強くならないと、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "怖くても進まないと、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "誰かを信じて、自分で選んで、"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "間に合った？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "どうかな"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "でも、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal3",
      "text": "全部、今も、私の中に残ってる"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "来た！"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "来た来た来た来た来たー！"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal3",
      "text": "時間が来たーーー！"
    },
