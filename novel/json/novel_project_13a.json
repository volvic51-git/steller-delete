    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal4",
      "text": "乙女機能インストール中・・・ピピピ"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal4",
      "text": "プププ\n"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal4",
      "text": "ポポポ"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal3",
      "text": "インストール完了"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "インストール？\n乙女機能？"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "つなぐために必要な機能"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "あと６個"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "次は犠牲になった話を聞きたい"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "よくわかんないけど"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "傷ついた話の続き？"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "続き　続き"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "周りから無視されるようになって、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "グループから外されたり、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "有ること無いこと言われたりした"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "理不尽　理不尽"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "今ならそう思う"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "当時は？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "大丈夫なふりしてた"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "全然大丈夫じゃなかった"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "庇ってあげた子も？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "そう"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "なぜ"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "その子も怖かったんだと思う"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "だから弱音吐いちゃダメだと思った"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal3",
      "text": "その子の方が辛そうだったから"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "来た！"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "来た来た来た来た来たー！"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal3",
      "text": "犠牲が来たーーー！"
    },
