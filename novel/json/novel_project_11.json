      "text": "え？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "待って待って待って。"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "登校中だったよね？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "え？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "私、死んだ？"
    },
    {
      "type": "narration",
      "text": "周囲を見回す。\nどこまでも続く暗い宇宙。"
    },
    {
      "type": "narration",
      "text": "遠くに無数の光。\n上も下も分からない。"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "いやいやいや。"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "死んだらスマホ持ってないでしょ。"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "・・・。"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "あった。"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "圏外。"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "ですよねー！\n知ってた！"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "宇宙だもん！"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "なんで宇宙なんだよ！！"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal3",
      "text": "・・・ん？"
    },
