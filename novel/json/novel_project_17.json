      "text": "ポポポ"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal3",
      "text": "インストール完了"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "ねぇ、全部集まったら終わり？"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "あと２個"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "教えてくれないんだ"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "次は決断の話を聞きたい"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "決断・・・"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "留学したことかな"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "不安だった？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "最初はね"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "とっても"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "じゃあ、どうして？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "エリカが言ってくれたんだ"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "エリカに助けられてばっかり"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "なんて言ったの？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "不安な道を選ぶんじゃなくて、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "納得できる道を選ぶんだって"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "それで決めたの？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "うん"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "怖かったけど・・・"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "あの日、飛行機に乗った瞬間、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "ワクワクもした"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "行ってよかった？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "嫌なこともあったよ"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "言葉が上手く伝わらなかったり"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "自分だけ輪に入れなかったり"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "また、傷ついた？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "そうだね"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "行った意味はなかった？"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "少しずつだけど、自分から話しかけた"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "一歩だけ踏み出した"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "偉大なる一歩"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal1",
      "text": "そしたらね"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal2",
      "text": "全部じゃないけど、"
    },
    {
      "type": "dialog",
      "speaker": "有栖",
      "portrait": "normal3",
      "text": "少しずつ変わっていった"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal1",
      "text": "来た！"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal2",
      "text": "来た来た来た来た来たー！"
    },
    {
      "type": "dialog",
      "speaker": "ニーファ",
      "portrait": "normal3",
      "text": "運命が来たーーー！"
    },
